apiVersion: security.istio.io/v1
kind: RequestAuthentication
metadata:
  name: default-{{ .To.ServiceName }}
spec:
  targetRefs:
  - kind: Gateway
    group: gateway.networking.k8s.io
    name: {{ .To.Config.ServiceWaypointProxy }}
  jwtRules:
  - issuer: "test-issuer-1@istio.io"
    jwks: '{{ .Jwks }}'
  - issuer: "test-issuer-2@istio.io"
    jwks: '{{ .Jwks }}'
---
apiVersion: security.istio.io/v1
kind: RequestAuthentication
metadata:
  name: ignored-{{ .To.ServiceName }}
spec:
  selector:
    matchLabels:
      gateway.networking.k8s.io/gateway-name: {{ .To.Config.ServiceWaypointProxy }} # This should be ignored because it's not a targetRef
  jwtRules:
  - issuer: "test-issuer-3@istio.io"
    jwks: '{{ .Jwks }}'
---
apiVersion: security.istio.io/v1
kind: AuthorizationPolicy
metadata:
  name: authz-gateway-{{ .To.ServiceName }}
spec:
  targetRefs:
  - kind: Gateway
    group: gateway.networking.k8s.io
    name: {{ .To.Config.ServiceWaypointProxy }}
  rules:
  - from:
    - source:
        requestPrincipals: ["test-issuer-1@istio.io/sub-1"]
    - source:
        requestPrincipals: ["test-issuer-3@istio.io/sub-1"]
  - to:
    - operation:
        paths: ["/healthz"]
