apiVersion: networking.istio.io/v1
kind: DestinationRule
metadata:
  annotations:
    internal.istio.io/parents: BackendTLSPolicy/default.tls-active
  name: echo~istio-autogenerated-k8s-gateway
  namespace: default
spec:
  host: echo.default.svc.domain.suffix
  trafficPolicy:
    tls:
      mode: SIMPLE
      sni: echo.example.com
---
