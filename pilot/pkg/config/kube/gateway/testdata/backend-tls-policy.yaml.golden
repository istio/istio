apiVersion: networking.istio.io/v1
kind: DestinationRule
metadata:
  creationTimestamp: null
  name: auth-istio-autogenerated-k8s-gateway
  namespace: default
spec:
  host: auth.default.svc.domain.suffix
  trafficPolicy:
    tls:
      credentialName: configmap://auth-cert
      sni: auth.example.com
---
