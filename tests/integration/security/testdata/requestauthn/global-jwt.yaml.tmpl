apiVersion: security.istio.io/v1
kind: RequestAuthentication
metadata:
  name: "default"
spec:
  jwtRules:
  - issuer: "test-issuer-1@istio.io"
    jwksUri: "{{ .JWTServer.JwksURI }}"
  - issuer: "test-issuer-2@istio.io"
    jwksUri: "{{ .JWTServer.JwksURI }}"
---
apiVersion: security.istio.io/v1
kind: AuthorizationPolicy
metadata:
  name: authz-ingress
spec:
  selector:
    matchLabels:
      istio: {{.GatewayIstioLabel | default "ingressgateway"}}
  rules:
  - to:
    - operation:
        hosts:
{{- range $svc := .Services }}
        - "example.{{ $svc.ServiceName }}.com"
{{- end }}
    from:
    - source:
        requestPrincipals: ["test-issuer-1@istio.io/sub-1"]
  - to:
    - operation:
        hosts:
  {{- range $svc := .Services }}
        - "any-request-principal-ok.{{ $svc.ServiceName }}.com"
  {{- end }}
    from:
    - source:
        requestPrincipals: ["*"]
  - to:
    - operation:
        paths: ["/healthz"]
