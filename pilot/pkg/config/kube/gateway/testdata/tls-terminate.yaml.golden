apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  annotations:
    internal.istio.io/gateway-semantics: gateway
    internal.istio.io/gateway-service: istio-ingressgateway.istio-system.svc.domain.suffix
    internal.istio.io/parents: Gateway/gateway/tls-passthrough.istio-system
    internal.istio.io/service-account-name: ""
  name: gateway~istio-autogenerated-k8s-gateway~tls-passthrough
  namespace: istio-system
spec:
  servers:
  - hosts:
    - '*/*'
    port:
      name: default
      number: 443
      protocol: TLS
    tls: {}
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  annotations:
    internal.istio.io/gateway-semantics: gateway
    internal.istio.io/gateway-service: istio-ingressgateway.istio-system.svc.domain.suffix
    internal.istio.io/parents: Gateway/gateway/tls-terminate.istio-system
    internal.istio.io/service-account-name: ""
  name: gateway~istio-autogenerated-k8s-gateway~tls-terminate
  namespace: istio-system
spec:
  servers:
  - hosts:
    - '*/example.com'
    port:
      name: default
      number: 443
      protocol: TLS
    tls:
      credentialName: kubernetes-gateway://istio-system/my-cert
      mode: SIMPLE
---
apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  annotations:
    internal.istio.io/gateway-semantics: gateway
    internal.istio.io/gateway-service: istio-ingressgateway.istio-system.svc.domain.suffix
    internal.istio.io/parents: Gateway/gateway/tls-wildcard.istio-system
    internal.istio.io/service-account-name: ""
  name: gateway~istio-autogenerated-k8s-gateway~tls-wildcard
  namespace: istio-system
spec:
  servers:
  - hosts:
    - '*/*.wild.example.com'
    port:
      name: default
      number: 9443
      protocol: TLS
    tls:
      credentialName: kubernetes-gateway://istio-system/my-cert
      mode: SIMPLE
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  annotations:
    internal.istio.io/parents: TLSRoute/tls-hostname-intersection-route.default
    internal.istio.io/route-semantics: gateway
  name: tls-hostname-intersection-route~tls~0~istio-autogenerated-k8s-gateway
  namespace: default
spec:
  gateways:
  - istio-system/gateway~istio-autogenerated-k8s-gateway~tls-wildcard
  hosts:
  - foo.wild.example.com
  tls:
  - match:
    - sniHosts:
      - foo.wild.example.com
      - bar.wild.example.com
    route:
    - destination:
        host: backend-wildcard.default.svc.domain.suffix
        port:
          number: 8080
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  annotations:
    internal.istio.io/parents: TLSRoute/tls-hostname-intersection-route.default
    internal.istio.io/route-semantics: gateway
  name: tls-hostname-intersection-route~tls~1~istio-autogenerated-k8s-gateway
  namespace: default
spec:
  gateways:
  - istio-system/gateway~istio-autogenerated-k8s-gateway~tls-wildcard
  hosts:
  - bar.wild.example.com
  tls:
  - match:
    - sniHosts:
      - foo.wild.example.com
      - bar.wild.example.com
    route:
    - destination:
        host: backend-wildcard.default.svc.domain.suffix
        port:
          number: 8080
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  annotations:
    internal.istio.io/parents: TLSRoute/tls-passthrough-route.default
    internal.istio.io/route-semantics: gateway
  name: tls-passthrough-route~tls~0~istio-autogenerated-k8s-gateway
  namespace: default
spec:
  gateways:
  - istio-system/gateway~istio-autogenerated-k8s-gateway~tls-passthrough
  hosts:
  - passthrough.example.com
  tls:
  - match:
    - sniHosts:
      - passthrough.example.com
    route:
    - destination:
        host: backend-passthrough.default.svc.domain.suffix
        port:
          number: 443
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  annotations:
    internal.istio.io/parents: TLSRoute/tls-terminate-route.default
    internal.istio.io/route-semantics: gateway
  name: tls-terminate-route~tls~0~istio-autogenerated-k8s-gateway
  namespace: default
spec:
  gateways:
  - istio-system/gateway~istio-autogenerated-k8s-gateway~tls-terminate
  hosts:
  - example.com
  tls:
  - match:
    - sniHosts:
      - example.com
    route:
    - destination:
        host: backend-terminate.default.svc.domain.suffix
        port:
          number: 8080
---
