apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  annotations:
    internal.istio.io/gateway-semantics: gateway
    internal.istio.io/gateway-service: istio-ingressgateway.istio-system.svc.domain.suffix
    internal.istio.io/parent-namespace: istio-system
    internal.istio.io/parents: ListenerSet/my-listener-set/https-listener.istio-system
    internal.istio.io/service-account-name: ""
  name: my-listener-set~istio-autogenerated-k8s-gateway~https-listener
  namespace: istio-system
spec:
  servers:
  - hosts:
    - istio-system/httpbin.example.com
    port:
      name: default
      number: 443
      protocol: HTTPS
    tls:
      credentialName: kubernetes-gateway://istio-system/my-cert-http
      mode: SIMPLE
---
