apiVersion: security.istio.io/v1
kind: RequestAuthentication
metadata:
  name: {{ .To.ServiceName }}-part1
spec:
  selector:
    matchLabels:
      app: {{ .To.ServiceName }}
  jwtRules:
  - issuer: "test-issuer-1@istio.io"
    jwksUri: "{{ .JWTServer.JwksURI }}"
    audiences:
    - "foo"
  - issuer: "test-issuer-2@istio.io"
    jwksUri: "{{ .JWTServer.JwksURI }}"
    audiences:
    - "bar"
---
apiVersion: security.istio.io/v1
kind: RequestAuthentication
metadata:
  name: {{ .To.ServiceName }}-part2
spec:
  selector:
    matchLabels:
      app: {{ .To.ServiceName }}
  jwtRules:
  - issuer: "test-issuer-2@istio.io"
    jwksUri: "{{ .JWTServer.JwksURI }}"
