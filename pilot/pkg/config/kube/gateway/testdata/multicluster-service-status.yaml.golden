apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  annotations:
    internal.istio.io/gateway-semantics: gateway
    internal.istio.io/gateway-service: istio-ingressgateway.istio-system.svc.domain.suffix
    internal.istio.io/parents: Gateway/gateway/default.istio-system
    internal.istio.io/service-account-name: ""
  name: gateway~istio-autogenerated-k8s-gateway~default
  namespace: istio-system
spec:
  servers:
  - hosts:
    - '*/*.domain.example'
    port:
      name: default
      number: 80
      protocol: HTTP
---
apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  annotations:
    internal.istio.io/parents: HTTPRoute/remote-backend.default
    internal.istio.io/route-semantics: gateway
  name: istio-system~gateway~istio-autogenerated-k8s-gateway~default~remote.domain.example
  namespace: default
spec:
  gateways:
  - istio-system/gateway~istio-autogenerated-k8s-gateway~default
  hosts:
  - remote.domain.example
  http:
  - match:
    - uri:
        prefix: /remote
    name: default.remote-backend.0
    route:
    - destination:
        host: remote-backend.default.svc.domain.suffix
        port:
          number: 80
---
